# Copy this file to .env and fill in your values
# Never commit .env to version control

# ── Docker / MSSQL container settings ────────────────────────────────────────
SA_PASSWORD=YourStrong!Passw0rd
ACCEPT_EULA=Y
MSSQL_PID=Developer

# ── extract.py connection settings ───────────────────────────────────────────
MSSQL_SERVER=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=lakehouse_source
MSSQL_USER=SA
MSSQL_PASSWORD=YourStrong!Passw0rd
# ODBC driver name as installed on your system:
#   "ODBC Driver 18 for SQL Server"  (default, recommended)
#   "ODBC Driver 17 for SQL Server"
MSSQL_DRIVER=ODBC Driver 18 for SQL Server
# Set to 1 to add TrustServerCertificate=yes (needed for self-signed certs)
MSSQL_TRUST_CERT=1

# ── Iceberg / LocalStack settings ────────────────────────────────────────────
# S3 endpoint override — needed when running outside Docker (host → LocalStack)
S3_ENDPOINT=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
